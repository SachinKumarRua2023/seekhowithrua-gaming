{
  "version": 2,
  "name": "seekhowithrua-gaming",
  "routes": [
    { "src": "/memory-game", "dest": "/memory-game.html" },
    { "src": "/train-memory", "dest": "/train-memory.html" },
    { "src": "/enhance-memory", "dest": "/enhance-memory.html" },
    { "src": "/memory-challenge", "dest": "/memory-challenge.html" },
    { "src": "/20x-memory", "dest": "/20x-memory.html" },
    { "src": "/50x-memory", "dest": "/50x-memory.html" },
    { "src": "/100x-memory", "dest": "/100x-memory.html" },
    { "src": "/200x-memory", "dest": "/200x-memory.html" }
  ],
  "headers": [
    {
      "source": "/sounds/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
